@prefix ms: <https://machinespirits.dev/ontology/reasoning#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

{ ?a rdfs:subClassOf ?b. ?b rdfs:subClassOf ?c } => { ?a rdfs:subClassOf ?c } .
{ ?x rdf:type ?c. ?c rdfs:subClassOf ?d } => { ?x rdf:type ?d } .

{ ?x rdf:type ?c. ?c ms:supportsPolicy ?p } => { ?x ms:supportsPolicy ?p } .
{ ?x rdf:type ?c. ?c ms:contraindicatesPolicy ?p } => { ?x ms:contraindicatesPolicy ?p } .
{ ?x rdf:type ?c. ?c ms:indicatesMissingKC ?kc } => { ?x ms:indicatesMissingKC ?kc } .
{ ?x rdf:type ?c. ?c ms:supportsRecognitionMove ?move } => { ?x ms:supportsRecognitionMove ?move } .
{ ?x rdf:type ?c. ?c ms:addressesToMState ?state } => { ?x ms:addressesToMState ?state } .

{ ?x ms:indicatesMissingKC ?kc. ?p ms:requiresKC ?kc } => { ?x ms:blocksPrematurePolicy ?p } .
