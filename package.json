{
  "name": "@machinespirits/eval",
  "version": "0.3.0",
  "description": "Evaluation system for Machine Spirits tutor - benchmarking, rubric evaluation, and analysis tools",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./services/*": "./services/*.js",
    "./routes/*": "./routes/*.js",
    "./config/*": "./config/*"
  },
  "files": [
    "index.js",
    "server.js",
    "routes/",
    "services/",
    "config/",
    "scripts/",
    "content/",
    "docs/research/"
  ],
  "scripts": {
    "start": "STANDALONE=true node server.js",
    "dev": "STANDALONE=true node server.js",
    "eval": "node scripts/eval-cli.js",
    "eval:quick": "node scripts/eval-cli.js quick",
    "eval:test": "node scripts/eval-cli.js test",
    "analyze:recognition-definitions": "node scripts/analyze-recognition-definitions.js",
    "analyze:effects": "node scripts/analyze-eval-results.js",
    "analyze:costs": "node scripts/analyze-eval-costs.js",
    "analyze:traces": "node scripts/analyze-mechanism-traces.js",
    "analyze:reliability": "node scripts/analyze-judge-reliability.js",
    "analyze:trajectories": "node scripts/analyze-trajectory-curves.js",
    "analyze:change": "node scripts/analyze-within-test-change.js",
    "analyze:modulation": "node scripts/analyze-modulation-learning.js",
    "analyze:stagnation": "node scripts/analyze-learning-stagnation.js",
    "seed": "node scripts/seed-db.js",
    "paper:bug-audit": "node scripts/validate-bug-claims.js",
    "paper:integrity-audit": "node scripts/validate-bug-claims.js",
    "paper:provable-discourse": "node scripts/validate-provable-discourse.js",
    "paper:provable-discourse:smoke": "node scripts/validate-provable-discourse.js --smoke",
    "paper:provable-discourse:todo": "node scripts/validate-provable-discourse.js --write-todo",
    "paper:provable-discourse:refresh-snapshot": "node scripts/validate-provable-discourse.js --refresh-snapshot",
    "paper:provable-discourse:sync-inventory": "node scripts/sync-provable-claim-inventory.js",
    "paper:provable-discourse:bootstrap": "node scripts/bootstrap-provable-claims.js",
    "paper:provable-discourse:test": "node --test tests/provableDiscourse.test.js",
    "paper:provable-discourse:reconstruct": "node scripts/reconstruct-provable-paper.js",
    "paper:provable-discourse:all": "npm run paper:provable-discourse:bootstrap && npm run paper:provable-discourse && npm run paper:provable-discourse:test",
    "paper:provable-discourse:chat": "node scripts/paper-provable-discourse-chat.js",
    "paper:provable-discourse:review": "node scripts/paper-provable-discourse-chat.js --no-augment-evidence --no-paper-edits",
    "paper:provable-discourse:augment": "node scripts/paper-provable-discourse-chat.js --take-action",
    "paper:bug-audit:chat": "node scripts/paper-bug-audit-chat.js",
    "audit:message-chain": "node scripts/audit-message-chain.js",
    "audit:message-chain:json": "node scripts/audit-message-chain.js --json",
    "test": "node --test --test-force-exit services/__tests__/*.test.js tests/*.test.js",
    "content:validate": "node scripts/validate-content.js",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "evaluation",
    "tutor",
    "benchmark",
    "rubric",
    "machine-spirits"
  ],
  "author": "L. Magee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/liammagee/machinespirits-eval"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "0.71.2",
    "@machinespirits/tutor-core": "^0.5.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "dependencies": {
    "better-sqlite3": "12.5.0",
    "chalk": "^5.6.2",
    "dotenv": "17.2.3",
    "express": "4.19.2",
    "jsonrepair": "3.13.2",
    "node-pty": "^1.0.0",
    "yaml": "2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "22.14.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "prettier": "^3.8.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
