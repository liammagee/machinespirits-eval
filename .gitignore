# Local compressed archives produced by scripts/package-poetics-run.js.
# Commit the manifest in config/poetics-calibration/runs/, not the bulk bundle.
artifacts/poetics-runs/

# Poetics sidecar run artifacts. Keep source specs, summaries, notes, scripts,
# and tests in Git; keep generated transcripts, deliberations, samples, scores,
# and per-run keys local only.
config/poetics-calibration/**/deliberation/
config/poetics-calibration/**/transcripts/
config/poetics-calibration/**/sample/
config/poetics-calibration/**/scores/
config/poetics-calibration/**/structure-critic/
config/poetics-calibration/**/batch-plan.json
config/poetics-calibration/**/key.yaml
config/poetics-calibration/**/key-*.yaml
config/poetics-calibration/phase2-sample*/
config/poetics-calibration/phase2-deliberation*/
# phase2-transcripts-*/ dirs slip the **/transcripts/ rule above (dir is named
# phase2-transcripts-api etc., not literally "transcripts") — match them explicitly:
config/poetics-calibration/phase2-transcripts*/
config/poetics-calibration/phase2-d42-readable-projection-v1/

