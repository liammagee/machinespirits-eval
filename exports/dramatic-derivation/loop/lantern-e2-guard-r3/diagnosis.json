  "staging": {
    "source": "director",
    "movements": [
      {
        "turn": 1,
        "name": "Act 1",
        "intent": "[The room settles under rain-streaked panes; papers lie unopened, and every face waits for the first name to be made blame. Outside, the harbor bell sounds once and is gone.]"
      },
      {
        "turn": 5,
        "name": "Act 2",
        "intent": "[The clerk closes the bearing-book without reading further, and the room’s first certainty is left standing beside a colder number. Rain softens to a steady hiss as the lamps within are turned lower, making the walls feel nearer and the next silence less forgiving.]"
      },
      {
        "turn": 10,
        "name": "Act 3",
        "intent": "[The chart is folded away, and the room seems larger for the absence it leaves: no longer a quarrel over duty, but a hollow place where something impossible must have stood. The clerk sets out a fresh sheet for the next witness, and the wet smell of the quay comes in with the opening door.]"
      },
      {
        "turn": 16,
        "name": "Act 4",
        "intent": "[The locksmith's book is closed, and the sound of its cover settles harder than the rain. The room shifts toward the windows and the quay beyond them, where the next pressure must come from weather, distance, and a body moving through both.]"
      }
    ],
    "tutorNotes": []
  },
