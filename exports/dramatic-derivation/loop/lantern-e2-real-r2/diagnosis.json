  "staging": {
    "source": "director",
    "movements": [
      {
        "turn": 1,
        "name": "Act 1",
        "intent": "[The inquiry room gathers itself under a hard morning light; wet coats steam at the rail, and the empty witness chair waits as if already accused. Outside the windows, the sea keeps striking the stones.]"
      },
      {
        "turn": 5,
        "name": "Act 2",
        "intent": "[The clerk closes no book, but the room changes around the open page: accusation has lost its easy shape and become a measured silence. Beyond the windows the rain thickens, and the next witness waits unseen behind the door.]"
      },
      {
        "turn": 10,
        "name": "Act 3",
        "intent": "[The chart is left open, but the room no longer looks at it; all faces turn instead toward the rain-black windows, where the coast itself seems to wait for inspection. The clerk sets out a clean sheet, and the inquiry passes from bearings and seals into the colder business of what a dark place may show when entered.]"
      },
      {
        "turn": 17,
        "name": "Act 4",
        "intent": "[The open book is closed at last, not with decision but with the small sound of a door giving way to weather. The room shifts from documents to movement, from possession to presence, and the next act enters on the hard question of who crossed the storm rather than who could.]"
      }
    ],
    "tutorNotes": []
  },
