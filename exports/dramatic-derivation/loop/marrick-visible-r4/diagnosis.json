    "source": "director",
    "movements": [
      {
        "turn": 1,
        "name": "Act 1",
        "intent": "[Rain beats on the fair-town windows, and the hearing room smells of wet wool, candle smoke, and coin handled too often. A narrow table waits beneath the magistrate's lamp, its empty space already drawing every eye toward the question it has not yet received.]"
      },
      {
        "turn": 5,
        "name": "Act 2",
        "intent": "[The ledger is closed with a soft slap, and the lamp is drawn nearer to the empty place beside the coin. Outside, the rain slackens into a colder drip, leaving the room sharper, quieter, and ready for metal to answer metal.]"
      },
      {
        "turn": 11,
        "name": "Act 3",
        "intent": "[The room is cleared to a harder brightness, and the quiet chain of metal gives way to the sound of feet and voices beyond the door. The next act enters under pressure: not with completion, but with interruption, noise, and a question split cleanly in two.]"
      },
      {
        "turn": 15,
        "name": "Act 4",
        "intent": "[The benches are stripped of their clamor; only the measured scrape of chairs and the small circle of lamplight remain. The next act enters with less noise and closer sight, pressing the room from accusation toward the marks that tools leave when hands have tried to hide behind them.]"
      }
    ],
    "tutorNotes": []
  },
