  "staging": {
    "source": "director",
    "movements": [
      {
        "turn": 1,
        "name": "Act 1",
        "intent": "[Rain rattles against the fair-hall shutters, and the table waits under a hard white wash of morning light. A magistrate's chair stands empty; beyond it, the town's certainty gathers like wet wool.]"
      },
      {
        "turn": 5,
        "name": "Act 2",
        "intent": "[The hall is cleared of the fair's clamor; a colder room receives ledgers beneath a low window, its panes dulled by rain. The morning narrows from accusation to material, and every silence asks where heat once was.]"
      },
      {
        "turn": 11,
        "name": "Act 3",
        "intent": "[The ledgers are closed without warmth, and the room seems to listen after the last page falls shut. Beyond the low window the rain thickens, and the next chamber waits with a sharper light, fit for interruption and reversal.]"
      },
      {
        "turn": 15,
        "name": "Act 4",
        "intent": "[The room gives back no answer, only the thin scrape of chair legs and the patient hiss of rain at the panes. The coins are covered with a dark cloth, and the next light falls not on faces but on tools, where small differences wait to become heavier than testimony.]"
      },
      {
        "turn": 21,
        "name": "Act 5",
        "intent": "[The rain slackens, leaving the panes beaded and silent, and the room seems suddenly too small for all its waiting. A fresh candle is set beside the closed books, not brighter than the last, but nearer to the place where a name must either enter or fail to enter.]"
      }
    ],
    "tutorNotes": []
  },
