    "movements": [
      {
        "turn": 1,
        "name": "Act 1",
        "intent": "[The hearing room gathers itself in a hard, expectant hush; wet coats darken the benches, and the table waits under a narrow spill of lamplight. Outside, the weather presses at the glass as if it too has come to hear a verdict.]"
      },
      {
        "turn": 5,
        "name": "Act 2",
        "intent": "[The bearing-book is left open under the lamp, its ruled line dark against the paper while the room's certainty finds no easy place to settle. Beyond the panes, the weather draws back into a lower, steadier mutter, and the next silence has less accusation in it than dread.]"
      },
      {
        "turn": 10,
        "name": "Act 3",
        "intent": "[The chart and bearing-book remain apart on the table, their agreement making the room colder rather than clearer. As the next act opens, the inquiry leaves ledgers and orders for the harsher business of things that can be handled, marked, and found wanting.]"
      },
      {
        "turn": 17,
        "name": "Act 4",
        "intent": "[The key remains on the table, bright under the court lamps and useless by itself. As the next act opens, the room turns from paper and metal toward wet thresholds, night weather, and the question of who crossed from shore into the storm.]"
      }
    ],
