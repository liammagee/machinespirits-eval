  "staging": {
    "source": "director",
    "movements": [
      {
        "turn": 1,
        "name": "Act 1",
        "intent": "[Rain rattles against the Marrick hall windows while the room gathers around a table left bare for testimony. Beyond the doors, the fair's noise thins into mutters, and the question of the light shillings hangs like damp wool in the air.]"
      },
      {
        "turn": 4,
        "name": "Act 2",
        "intent": "[The bare table is wiped clean, yet the room feels more crowded than before. A brazier is brought nearer against the wet cold, and its dull heat turns every waiting face toward the next question in the chain.]"
      },
      {
        "turn": 11,
        "name": "Act 3",
        "intent": "[The first bundle of papers is tied shut and taken from the table, leaving only the lamp, the scales, and a clean sheet where the next hand might appear. Outside, the rain hardens against the shutters, and the room gathers itself for a sharper noise than metal cooling.]"
      },
      {
        "turn": 15,
        "name": "Act 4",
        "intent": "[The glass is covered, and the clean sheet is turned so its blank lower half faces the lamp. The room narrows from accusation into comparison, every sound made smaller and more exact.]"
      },
      {
        "turn": 22,
        "name": "Act 5",
        "intent": "[The clerk breaks the seal on the estate inventory and reads it into the room: \"The old founder's tools were never sold off. The inventory of his estate, sworn and unredeemed, leaves his graving-irons to his widow alone — among them the worn burin with the sprung heel, kept in Edony's keeping these ten years.\"]"
      }
    ],
    "tutorNotes": []
  },
