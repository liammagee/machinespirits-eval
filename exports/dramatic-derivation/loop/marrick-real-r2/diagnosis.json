  "staging": {
    "source": "director",
    "movements": [
      {
        "turn": 1,
        "name": "Act 1",
        "intent": "[Rain frets at the shutters while the hearing room settles into its first silence. On the table, a covered tray waits beneath a stained cloth, and every face turns toward the question before any mouth has shaped it.]"
      },
      {
        "turn": 5,
        "name": "Act 2",
        "intent": "[The cupel's dull bowl is lifted away, leaving the table poorer and the question sharper. Beyond the shutters the rain slackens into a cold drip, and the room turns from the public verdict toward darker metal-work no one is yet ready to name.]"
      },
      {
        "turn": 11,
        "name": "Act 3",
        "intent": "[The room is cleared to its barest shape: wet coats on pegs, a low fire, and the table waiting under a sharper light. From beyond the door comes the murmur of a crowd rehearsing its certainty, and the next act opens under that pressure.]"
      },
      {
        "turn": 14,
        "name": "Act 4",
        "intent": "[The room changes: the crowd falls back to a mutter, and the lamp is lowered until every face has to lean toward the table. The next act begins slower and closer, with certainty made to answer to the small marks it has ignored.]"
      },
      {
        "turn": 20,
        "name": "Act 5",
        "intent": "[The clerk sands the untouched page and closes the box with a small, dry click. The next act opens under a harder quiet: fewer voices, less shelter, and only the kept shape of the proof left standing between hesitation and a name.]"
      }
    ],
    "tutorNotes": []
  },
