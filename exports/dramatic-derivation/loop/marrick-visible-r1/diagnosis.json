  "staging": {
    "source": "director",
    "movements": [
      {
        "turn": 1,
        "name": "Act 1",
        "intent": "[Rain presses at the shuttered room while the fair's mud dries in black seams along the floorboards. A covered tray waits on the table, and every face in the room seems already to have chosen a hand before any proof is named.]"
      },
      {
        "turn": 5,
        "name": "Act 2",
        "intent": "[The tray is covered again, but the room no longer rests easy around it; rain ticks in the silence where the town's first answer had stood. The next chamber waits colder, with ledgers, ash, and metal asked to remember what mouths will not.]"
      },
      {
        "turn": 11,
        "name": "Act 3",
        "intent": "[The covered tray is carried out, and the silence it leaves behind feels less settled than before. The next room opens with harder light, quicker footsteps, and a pressure that makes every partial answer prove whether it can stand without the rest.]"
      },
      {
        "turn": 14,
        "name": "Act 4",
        "intent": "[The narrow pane of light shifts off the coin and onto the empty space beside it, as if the table itself has made room for a second witness. The room tightens into a quieter pressure now, less clamorous and more exacting, where only a thing that fits the mark may be allowed to speak.]"
      },
      {
        "turn": 19,
        "name": "Act 5",
        "intent": "[The chamber sheds its patience without raising its voice. The coin, the glass, and the blank column lie in a hard triangle of lamplight, and the next movement in the room must answer to all three or be refused.]"
      }
    ],
    "tutorNotes": []
  },
