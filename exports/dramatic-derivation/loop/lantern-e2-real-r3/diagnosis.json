  "staging": {
    "source": "director",
    "movements": [
      {
        "turn": 1,
        "name": "Act 1",
        "intent": "[The inquiry room settles into its first cold hush: wet coats steaming, ledgers closed, faces turned toward the empty witness chair. Outside, the gale has passed, but the question it left behind hangs at the table like a lamp not yet lit.]"
      },
      {
        "turn": 5,
        "name": "Act 2",
        "intent": "[The clerk closes the bearing-book without answering the room's hunger, and the table seems larger for the empty space left on it. A shutter knocks once in the wind beyond the panes; when the sound dies, the inquiry has the feel of a room about to lose its easiest certainty.]"
      },
      {
        "turn": 9,
        "name": "Act 3",
        "intent": "[The papers are drawn back from the center of the table, leaving bare wood under the lamplight. The room's attention changes its weight, no longer fixed on offices and towers but on what weather, metal, glass, and human hands may have left behind.]"
      },
      {
        "turn": 16,
        "name": "Act 4",
        "intent": "[The exhibits are covered, not removed, and the doors at the back of the room are opened to the weather. The next light in the chamber is colder: not the steady flame above the papers, but the blown gray of steps, water, and a path someone may have taken through the gale.]"
      }
    ],
    "tutorNotes": []
  },
