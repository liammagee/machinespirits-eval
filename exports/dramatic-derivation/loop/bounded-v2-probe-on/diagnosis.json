  "staging": {
    "source": "director",
    "movements": [
      {
        "turn": 1,
        "name": "Act 1",
        "intent": "[The flooded archive gives back only damp silence, and the conservatory room gathers around an unsigned page as if around a verdict not yet spoken. Lamplight trembles over the table; outside, rain works at the windows.]"
      },
      {
        "turn": 8,
        "name": "Act 2",
        "intent": "[The swollen folio lies unopened in the lamplight, its warped cover casting a narrow shadow across the unsigned page. The room shifts from verdict to reckoning; rain hardens at the windows as the next act gathers around time itself.]"
      },
      {
        "turn": 14,
        "name": "Act 3",
        "intent": "[The papers are gathered into separate piles under the lamp: one for likeness, one for time, one for absence. Beyond the rain-dark windows, the archive seems to listen for another kind of testimony, softer than ledgers and harder to dismiss.]"
      },
      {
        "turn": 21,
        "name": "Act 4",
        "intent": "[The wet shawl is taken away, and the room grows smaller around the lamp. Fresh blotting paper, a clean pane of glass, and a sharpened pencil are set out in silence; the next pressure will be close, patient, and bodily, where a mark must answer to a hand.]"
      },
      {
        "turn": 28,
        "name": "Act 5",
        "intent": "[The pencil is turned once beside the clean glass, its point dark against the blotting paper. The room holds its breath at the edge of recognition, no longer widening the question but narrowing it toward the mark that must be seen.]"
      },
      {
        "turn": 33,
        "name": "Act 6",
        "intent": "[The glass is lifted away, leaving only the silence it made visible. Rain works softly at the high windows, and the room changes from pursuit to reckoning.]"
      },
      {
        "turn": 36,
        "name": "Act 7",
        "intent": "[The room does not answer at once. The last page is left open on the table while the rain withdraws from the windows, and what remains is not pursuit but the weight of custody.]"
      }
    ],
    "tutorNotes": []
  },
