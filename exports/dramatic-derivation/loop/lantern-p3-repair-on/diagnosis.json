  "staging": {
    "source": "director",
    "movements": [
      {
        "turn": 1,
        "name": "Act 1",
        "intent": "[The hearing room gathers itself under a thin morning light; wet coats steam at the rail, and the empty witness chair faces the bench. A clerk sets a clean sheet beside the inkwell, leaving the first line blank.]"
      },
      {
        "turn": 5,
        "name": "Act 2",
        "intent": "[The map-case is carried nearer but not opened; its straps creak in the room's held breath. Outside, the rain slackens to a thin hiss, and the bench seems to wait for certainty to find either a door or a void.]"
      },
      {
        "turn": 9,
        "name": "Act 3",
        "intent": "[The chart is folded back into its case, leaving the room larger and less certain than before. A salt-stained packet is set at the clerk's elbow, unopened, and the inquiry turns from bearings and orders toward what touch, soot, and silence may be made to bear.]"
      },
      {
        "turn": 16,
        "name": "Act 4",
        "intent": "[The clerk closes the empty docket with more care than force, and the room exhales as if the air itself has been cross-examined. Beyond the windows, the gale shifts against the glass; when the next door opens, the inquiry will no longer be content with papers alone.]"
      },
      {
        "turn": 19,
        "name": "Act 5",
        "intent": "[For a moment the court gives no answer back; the rain and the lamps have the room between them. The clerk's pen hovers above the page, and the silence that follows is no longer empty but waiting to be entered.]"
      }
    ],
    "tutorNotes": []
  },
