    "movements": [
      {
        "turn": 1,
        "name": "Act 1",
        "intent": "[The room settles under a hard coastal light, benches close and breath held, as if the wreck has already found its culprit before any tongue names one. A blank space waits on the table where the first paper will be laid.]"
      },
      {
        "turn": 5,
        "name": "Act 2",
        "intent": "[The first roomful of certainty thins into a colder patience; what seemed ready to close now hangs on the next seal, the next absence, the next hard check against the night. The benches shift, not louder but less sure, as if the charge must pass through a narrower door.]"
      },
      {
        "turn": 10,
        "name": "Act 3",
        "intent": "[The emptied room changes its weight; accusation gives way to inspection, and every surface seems to wait for the mark of a hand. Outside, the gale presses the panes while the court orders no answer aloud, only the next thing brought in from the dark.]"
      },
      {
        "turn": 16,
        "name": "Act 4",
        "intent": "[The room lets the unfinished name hang without ink. Beyond the windows the weather changes from testimony to summons, and the next act opens with motion: doors, wet coats, and the pressure of a road leading back toward the dark.]"
      }
    ],
    "tutorNotes": []
  },
