  "staging": {
    "source": "director",
    "movements": [
      {
        "turn": 1,
        "name": "Act 1",
        "intent": "[The hearing room settles under a low ceiling of smoke and rain-silvered glass; clerks straighten their papers while the empty witness chair faces the bench. Outside, the sea keeps knocking at the harbor wall.]"
      },
      {
        "turn": 6,
        "name": "Act 2",
        "intent": "[A second log is carried in under seal, and the clerk reads it into the hush: Brandt's log has him at his post the night entire, and the dawn relief found him there: wood dry, glass polished, log ruled and signed to the hour. The room shifts from easy charge to colder pressure, where presence and responsibility no longer sit as neatly in the same chair.]"
      },
      {
        "turn": 9,
        "name": "Act 3",
        "intent": "[The easy accusation has gone out of the room, leaving every face turned toward the same absence. A salt-stiff canvas bundle is laid unopened on the table, and the next silence waits on inspection rather than blame.]"
      },
      {
        "turn": 16,
        "name": "Act 4",
        "intent": "[The exhibits are cleared to the edge of the table, leaving an empty square of wood where a person would have to stand. The room changes its breath: no more inventory, no more mechanism, only the weather pressing at the threshold and the question of a body in it.]"
      }
    ],
    "tutorNotes": []
  },
