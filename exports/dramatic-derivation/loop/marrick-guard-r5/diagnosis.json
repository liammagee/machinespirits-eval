  "staging": {
    "source": "director",
    "movements": [
      {
        "turn": 1,
        "name": "Act 1",
        "intent": "[Rain ticks against the shutters and the fair-room smells of wet wool, hot rushlight, and iron-stained mud. On the table, a shallow tray waits under a linen cloth while the town's impatience gathers around it.]"
      },
      {
        "turn": 4,
        "name": "Act 2",
        "intent": "[The cloth lies folded back now, and the room's first certainty has gone thin in the draught. Beyond the shutters the fair keeps muttering under rain, while the table is cleared for colder vessels and slower hands.]"
      },
      {
        "turn": 11,
        "name": "Act 3",
        "intent": "[The first ledger is closed and left face down beneath the lamp, its weight still present though its words are gone from view. A sharper noise enters with the rain now: boots in the passage, a watchman's knock, and the room turns from cold vessels toward nights, alibis, and the marks a coin may carry.]"
      },
      {
        "turn": 15,
        "name": "Act 4",
        "intent": "[The lamp is lowered until the coins and the empty space beside them seem to share one circle of light. Outside, the rain slackens, and the room narrows from witnesses and alibis toward the small instruments by which marks are made.]"
      },
      {
        "turn": 22,
        "name": "Act 5",
        "intent": "[The estate inventory is laid beneath the lamp, its seal cracked before the room. \"The old founder's tools were never sold off. The inventory of his estate, sworn and unredeemed, leaves his graving-irons to his widow alone — among them the worn burin with the sprung heel, kept in Edony's keeping these ten years.\" The room narrows to the silence after a name has reached its mark.]"
      }
    ],
    "tutorNotes": []
  },
