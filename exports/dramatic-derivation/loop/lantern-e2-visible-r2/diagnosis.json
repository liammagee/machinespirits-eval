  "staging": {
    "source": "director",
    "movements": [
      {
        "turn": 1,
        "name": "Act 1",
        "intent": "[The hearing room gathers itself around an empty table, its lamps low and its windows black with weather. A clerk lays out clean paper as though the room already knows what answer it means to write.]"
      },
      {
        "turn": 5,
        "name": "Act 2",
        "intent": "[The wet page lies beside the key, and the space between them seems wider than the table. The room's first certainty has thinned into a measured silence, with every face turned now toward the chart cabinet and its unopened drawers.]"
      },
      {
        "turn": 9,
        "name": "Act 3",
        "intent": "[The chart drawer is closed, and the room seems to darken around the answer it has given. Beyond the windows the coast waits in rain and black glass, while the table clears for an inquiry no longer aimed at the living tower but at the place everyone has avoided naming aloud.]"
      },
      {
        "turn": 15,
        "name": "Act 4",
        "intent": "[The lamp-room papers are gathered away, leaving the table bare except for the unanswered space where a hand must be. Outside, the gale presses at the windows as if the inquiry has moved from instruments and seals toward footsteps, weather, and the dangerous business of placing a person in the dark.]"
      }
    ],
    "tutorNotes": []
  },
